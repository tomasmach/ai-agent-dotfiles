#!/usr/bin/env bash
set -euo pipefail

root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$root"
failures=0

for forbidden in auth.json .claude.json history.jsonl; do
  if git ls-files | awk -F/ -v name="$forbidden" '$NF == name {print}' | grep -q .; then
    printf 'forbidden tracked filename: %s\n' "$forbidden" >&2
    failures=$((failures + 1))
  fi
done

pattern='(AKIA[0-9A-Z]{16}|ASIA[0-9A-Z]{16}|gh[opusr]_[A-Za-z0-9_]{20,}|github_pat_[A-Za-z0-9_]{20,}|sk-[A-Za-z0-9_-]{20,}|sk-ant-[A-Za-z0-9_-]{20,}|-----BEGIN ([A-Z ]+ )?PRIVATE KEY-----|[A-Za-z0-9+/]{40,}={0,2})'
if git grep -nEI "$pattern" -- . ':!scripts/secret-scan' ':!manifests/*.json' ':!LICENSE' > .secret-scan-results.tmp 2>/dev/null; then
  printf 'possible secret-like values found:\n' >&2
  sed -n '1,80p' .secret-scan-results.tmp >&2
  failures=$((failures + 1))
fi
rm -f .secret-scan-results.tmp

assignment_pattern="(api[_-]?key|auth[_-]?token|password|client[_-]?secret)[[:space:]]*[:=][[:space:]]*['\"][^\$<{][^'\"]{7,}"
if git grep -nEI "$assignment_pattern" -- . ':!scripts/secret-scan' ':!shell/claudex.env.example' > .secret-scan-results.tmp 2>/dev/null; then
  printf 'possible assigned credentials found:\n' >&2
  sed -n '1,80p' .secret-scan-results.tmp >&2
  failures=$((failures + 1))
fi
rm -f .secret-scan-results.tmp

if git grep -nE '/Users/tomasmach|/home/tomasmach' -- . ':!docs/*' ':!scripts/secret-scan' > .secret-scan-results.tmp 2>/dev/null; then
  printf 'machine-specific home paths found:\n' >&2
  sed -n '1,80p' .secret-scan-results.tmp >&2
  failures=$((failures + 1))
fi
rm -f .secret-scan-results.tmp

if [[ "$failures" -ne 0 ]]; then
  printf 'Secret scan failed with %d finding group(s).\n' "$failures" >&2
  exit 1
fi
printf 'Secret scan passed.\n'

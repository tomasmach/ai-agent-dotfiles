#!/usr/bin/env bash
set -euo pipefail

env_file="${CLAUDEX_ENV_FILE:-$HOME/.config/claudex/env}"
if [[ ! -r "$env_file" ]]; then
  printf 'claudex: missing readable environment file: %s\n' "$env_file" >&2
  printf 'Copy shell/claudex.env.example there and chmod 600.\n' >&2
  exit 1
fi

mode="$(stat -f '%Lp' "$env_file" 2>/dev/null || stat -c '%a' "$env_file" 2>/dev/null || true)"
if [[ "$mode" != "600" && "$mode" != "400" ]]; then
  printf 'claudex: %s must have mode 600 or 400 (current: %s)\n' "$env_file" "${mode:-unknown}" >&2
  exit 1
fi

set -a
# shellcheck disable=SC1090
source "$env_file"
set +a

: "${ANTHROPIC_AUTH_TOKEN:?ANTHROPIC_AUTH_TOKEN is required in $env_file}"
export CLAUDE_CONFIG_DIR="${CLAUDE_CONFIG_DIR:-$HOME/.claudex}"
export ANTHROPIC_BASE_URL="${ANTHROPIC_BASE_URL:-http://127.0.0.1:8317}"
export CLAUDE_CODE_ALWAYS_ENABLE_EFFORT="${CLAUDE_CODE_ALWAYS_ENABLE_EFFORT:-1}"
export CLAUDE_CODE_MAX_TOOL_USE_CONCURRENCY="${CLAUDE_CODE_MAX_TOOL_USE_CONCURRENCY:-3}"
export CLAUDE_CODE_AUTO_COMPACT_WINDOW="${CLAUDE_CODE_AUTO_COMPACT_WINDOW:-320000}"
export CLAUDE_AUTOCOMPACT_PCT_OVERRIDE="${CLAUDE_AUTOCOMPACT_PCT_OVERRIDE:-95}"
export ENABLE_TOOL_SEARCH="${ENABLE_TOOL_SEARCH:-true}"
unset ANTHROPIC_API_KEY

claude_bin="${CLAUDE_BIN:-$(command -v claude || true)}"
if [[ -z "$claude_bin" ]]; then
  printf 'claudex: claude executable not found; set CLAUDE_BIN in %s\n' "$env_file" >&2
  exit 1
fi

exec "$claude_bin" \
  --model "${CLAUDEX_MODEL:-gpt-5.6-sol}" \
  --effort "${CLAUDEX_EFFORT:-high}" \
  --dangerously-skip-permissions \
  "$@"
